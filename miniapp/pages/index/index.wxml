<view class="container">
  <!-- 拍照 / 相册 -->
  <view class="photo-row">
    <button class="photo-btn" bindtap="takePhoto">📷 拍照</button>
    <button class="photo-btn" bindtap="pickImage">🖼 相册{{images.length?'('+images.length+')':''}}</button>
  </view>

  <!-- 图片预览 -->
  <view class="preview-grid" wx:if="{{images.length}}">
    <view class="preview-item" wx:for="{{images}}" wx:key="index">
      <image class="preview-img" src="{{item.path}}" mode="aspectFill"/>
      <view class="preview-remove" bindtap="removeImage" data-index="{{index}}">✕</view>
      <text class="preview-num">{{index+1}}/{{images.length}}</text>
    </view>
  </view>

  <view class="divider">
    <text class="divider-text">或直接输入文字</text>
  </view>

  <!-- 输入 -->
  <view class="input-group">
    <textarea
      class="input-essay"
      placeholder="输入作业内容，支持文字批改。拍照上传则由AI直接看图识别..."
      value="{{essay}}"
      bindinput="onEssay"
      maxlength="5000"
      auto-height
    />
    <view class="word-count {{essay.length > 0 && essay.length < 10 ? 'warn' : ''}}">
      {{essay.length}}/5000
      <text wx:if="{{essay.length > 0 && essay.length < 10}}" class="warn-text">（至少10字）</text>
    </view>
  </view>

  <!-- 提交 -->
  <button class="submit-btn" bindtap="submit" loading="{{loading}}" disabled="{{loading}}">
    {{loading ? 'AI批改中...' : '提交批改'}}
  </button>

  <!-- 加载动画 -->
  <view class="loading-card" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-timer">已等待 {{elapsed}} 秒</text>
    <text class="loading-tip">{{currentTip}}</text>
    <view class="loading-dots">
      <view class="dot {{elapsed >= 5 ? 'active' : ''}}"></view>
      <view class="dot {{elapsed >= 15 ? 'active' : ''}}"></view>
      <view class="dot {{elapsed >= 30 ? 'active' : ''}}"></view>
      <view class="dot {{elapsed >= 45 ? 'active' : ''}}"></view>
    </view>
    <text class="loading-dot-label">识别中 → 分析中 → 批改中 → 生成结果</text>
  </view>
</view>
