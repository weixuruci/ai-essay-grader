.container { background: #F9FAFB; min-height: 100vh; padding-bottom: 16px; }

/* 视图切换 */
.view-toggle { display: flex; padding: 8px 16px; background: white; gap: 4px; }
.toggle-item {
  flex: 1; text-align: center; padding: 8px 0; font-size: 14px;
  color: #9CA3AF; border-radius: 8px; background: #F3F4F6;
}
.toggle-item.active { color: white; background: #4F46E5; }

/* 筛选 */
.filter-bar {
  white-space: nowrap; padding: 12px 16px;
  background: white; position: sticky; top: 0; z-index: 10;
  border-bottom: 1px solid #F3F4F6;
}
.filter-tag {
  display: inline-block; padding: 6px 14px; margin-right: 8px;
  font-size: 13px; color: #6B7280; background: #F3F4F6;
  border-radius: 99px;
}
.filter-tag.active { color: white; background: #4F46E5; }

/* 空 */
.empty { text-align: center; padding: 60px 20px; }
.empty-icon { font-size: 48px; display: block; margin-bottom: 12px; }
.empty-text { font-size: 16px; color: #6B7280; display: block; margin-bottom: 4px; }
.empty-desc { font-size: 13px; color: #D1D5DB; }

/* 列表卡片 */
.record-card {
  display: flex; gap: 12px; background: white; border-radius: 12px;
  padding: 14px; margin: 10px 16px; align-items: center;
}
.record-left {
  width: 52px; height: 52px; border-radius: 12px;
  background: #F3F4F6; display: flex; flex-direction: column;
  align-items: center; justify-content: center; flex-shrink: 0;
}
.record-score { font-size: 22px; font-weight: 800; color: #4F46E5; line-height: 1; }
.record-score.good { color: #10B981; }
.record-score.bad { color: #EF4444; }
.record-unit { font-size: 10px; color: #9CA3AF; }
.record-right { flex: 1; min-width: 0; }
.record-title {
  font-size: 15px; font-weight: 600; color: #1F2937; display: block;
  margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.record-summary {
  font-size: 13px; color: #6B7280; display: block; margin-bottom: 6px;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.record-meta { font-size: 11px; color: #D1D5DB; }

/* ====== 趋势 ====== */
.trend-section { padding: 0 16px; }
.trend-header {
  background: white; border-radius: 12px; padding: 14px;
  margin-bottom: 10px;
}
.trend-title { font-size: 16px; font-weight: 700; color: #1F2937; display: block; margin-bottom: 8px; }
.trend-stats { font-size: 12px; color: #9CA3AF; display: flex; gap: 12px; }
.stat-high { color: #10B981; font-weight: 600; }
.stat-low { color: #EF4444; font-weight: 600; }
.stat-avg { color: #4F46E5; font-weight: 600; }

/* 柱状图 */
.chart {
  background: white; border-radius: 12px; padding: 16px;
  height: 280px; position: relative;
}
.chart-grid {
  position: absolute; left: 0; right: 0; top: 16px; bottom: 40px;
}
.grid-line {
  position: absolute; left: 0; right: 0; height: 1px;
  background: #F3F4F6;
}
.grid-line text {
  position: absolute; left: 4px; top: -10px; font-size: 10px; color: #D1D5DB;
}
.chart-bars {
  position: absolute; left: 24px; right: 8px; bottom: 40px; top: 16px;
  display: flex; align-items: flex-end;
}
.bar-wrap { display: flex; flex-direction: column; align-items: center; height: 100%; }
.bar {
  width: 24px; max-width: 80%; border-radius: 4px 4px 0 0;
  background: #6366F1; transition: height 0.5s; min-height: 2px;
}
.bar.bar-good { background: #10B981; }
.bar.bar-bad { background: #EF4444; }
.bar-label {
  font-size: 10px; font-weight: 600; color: #6B7280; margin-top: 4px;
}
.bar-date {
  font-size: 9px; color: #D1D5DB;
}
