.container { background: #F9FAFB; min-height: 100vh; }

.filter-bar {
  white-space: nowrap; padding: 12px 16px;
  background: white; position: sticky; top: 0; z-index: 10;
  border-bottom: 1px solid #F3F4F6;
}
.filter-tag {
  display: inline-block; padding: 6px 14px; margin-right: 8px;
  font-size: 13px; color: #6B7280; background: #F3F4F6;
  border-radius: 99px;
}
.filter-tag.active { color: white; background: #4F46E5; }

.empty { text-align: center; padding: 80px 20px; }
.empty-icon { font-size: 48px; display: block; margin-bottom: 12px; }
.empty-text { font-size: 16px; color: #6B7280; display: block; margin-bottom: 4px; }
.empty-desc { font-size: 13px; color: #D1D5DB; }

.error-card {
  background: white; border-radius: 12px; padding: 14px;
  margin: 10px 16px; border-left: 3px solid #EF4444;
}
.error-header { display: flex; justify-content: space-between; margin-bottom: 8px; }
.error-subject {
  font-size: 11px; color: white; background: #EF4444;
  padding: 1px 8px; border-radius: 4px;
}
.error-date { font-size: 11px; color: #D1D5DB; }

.error-body { margin-bottom: 8px; }
.error-row { display: flex; gap: 8px; margin-bottom: 6px; align-items: flex-start; }
.error-tag {
  font-size: 11px; padding: 1px 6px; border-radius: 4px; flex-shrink: 0; margin-top: 2px;
}
.error-tag.bad { background: #FEE2E2; color: #DC2626; }
.error-tag.good { background: #D1FAE5; color: #059669; }
.error-text { font-size: 14px; line-height: 1.6; color: #374151; flex: 1; }
.error-text.correct { color: #059669; }
.error-reason { font-size: 12px; color: #9CA3AF; padding-top: 4px; border-top: 1px solid #F3F4F6; }
