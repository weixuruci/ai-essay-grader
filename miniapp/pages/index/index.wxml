<view class="container">
  <!-- 头部 -->
  <view class="hero">
    <text class="hero-icon">📝</text>
    <text class="hero-title">AI 作文批改</text>
    <text class="hero-desc">输入作文，秒出批改结果</text>
  </view>

  <!-- 年级选择 -->
  <view class="grade-row">
    <view class="grade-item {{grade==='小学'?'active':''}}" bindtap="pickGrade" data-grade="小学">小学</view>
    <view class="grade-item {{grade==='初中'?'active':''}}" bindtap="pickGrade" data-grade="初中">初中</view>
    <view class="grade-item {{grade==='高中'?'active':''}}" bindtap="pickGrade" data-grade="高中">高中</view>
  </view>

  <!-- 题目 -->
  <input class="input-title" placeholder="作文题目（选填）" value="{{title}}" bindinput="onTitle" maxlength="30" />

  <!-- 作文输入 -->
  <view class="textarea-wrap">
    <textarea
      class="textarea"
      placeholder="请输入作文内容（至少50字）&#10;&#10;支持手写后拍照识别文字粘贴到这里"
      value="{{essay}}"
      bindinput="onEssay"
      maxlength="5000"
      auto-height
    />
    <view class="textarea-footer">
      <text class="word-count {{essay.length<50?'warn':''}}">{{essay.length}}字</text>
      <text class="word-hint">/ 至少50字</text>
    </view>
  </view>

  <!-- 提交按钮 -->
  <button class="btn-primary" bindtap="submit" disabled="{{essay.length<50||loading}}" loading="{{loading}}">
    {{loading ? 'AI 正在批改...' : '开始批改'}}
  </button>

  <!-- 底部提示 -->
  <view class="footer-tip">
    <text>🆓 每天免费批改 1 次 · 仅需几秒</text>
  </view>
</view>
