.empty {
  text-align: center;
  padding: 60px 20px;
}
.empty-icon { font-size: 48px; display: block; margin-bottom: 12px; }
.empty-text { font-size: 16px; color: #6B7280; display: block; margin-bottom: 4px; }
.empty-desc { font-size: 13px; color: #D1D5DB; }

.record-card {
  display: flex;
  gap: 12px;
  background: white;
  border-radius: 12px;
  padding: 14px;
  margin-bottom: 10px;
  align-items: center;
}
.record-left {
  width: 52px;
  height: 52px;
  border-radius: 12px;
  background: #F3F4F6;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.record-score { font-size: 22px; font-weight: 800; color: #4F46E5; line-height: 1; }
.record-score.good { color: #10B981; }
.record-score.bad { color: #EF4444; }
.record-unit { font-size: 10px; color: #9CA3AF; }
.record-right { flex: 1; min-width: 0; }
.record-title {
  font-size: 15px;
  font-weight: 600;
  color: #1F2937;
  display: block;
  margin-bottom: 4px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.record-summary {
  font-size: 13px;
  color: #6B7280;
  display: block;
  margin-bottom: 6px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.record-meta { font-size: 11px; color: #D1D5DB; }
