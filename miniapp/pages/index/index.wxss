.container { padding: 16px; min-height: 100vh; background: #F9FAFB; }

.photo-row { display: flex; gap: 10px; margin-bottom: 12px; }
.photo-btn {
  flex: 1; font-size: 14px; padding: 12px 0;
  background: white; color: #4F46E5; border: 1.5px dashed #C7D2FE;
  border-radius: 10px; line-height: 1.4;
}
.photo-btn::after { border: none; }

/* 多图预览 */
.preview-grid { display: flex; gap: 8px; margin-bottom: 12px; overflow-x: auto; }
.preview-item {
  flex-shrink: 0; width: 100px; height: 100px;
  border-radius: 10px; overflow: hidden; position: relative;
  border: 1px solid #E5E7EB;
}
.preview-img { width: 100%; height: 100%; }
.preview-remove {
  position: absolute; top: 4px; right: 4px;
  width: 20px; height: 20px; border-radius: 50%;
  background: rgba(0,0,0,0.5); color: white;
  text-align: center; line-height: 20px; font-size: 12px;
}
.preview-num {
  position: absolute; bottom: 4px; left: 4px;
  font-size: 10px; color: white; background: rgba(0,0,0,0.5);
  padding: 1px 5px; border-radius: 4px;
}

.divider { text-align: center; margin-bottom: 12px; }
.divider-text { font-size: 12px; color: #D1D5DB; }

.input-group { margin-bottom: 12px; position: relative; }
.input-essay {
  width: 100%; min-height: 140px; font-size: 15px; line-height: 1.8;
  padding: 14px; background: white; border-radius: 10px;
  border: 1px solid #E5E7EB; box-sizing: border-box;
}
.word-count { text-align: right; font-size: 12px; color: #9CA3AF; padding: 4px 4px 0; }
.word-count.warn { color: #EF4444; }
.warn-text { margin-left: 4px; }

.submit-btn {
  width: 100%; margin-top: 8px; padding: 14px 0;
  font-size: 16px; font-weight: 600; color: white;
  background: linear-gradient(135deg, #6366F1, #8B5CF6);
  border-radius: 12px; border: none;
}
.submit-btn[disabled] { opacity: 0.6; }
.submit-btn::after { border: none; }

/* 加载 */
.loading-card {
  margin-top: 16px; padding: 24px; background: white;
  border-radius: 12px; text-align: center;
}
.loading-spinner {
  width: 40px; height: 40px; margin: 0 auto 12px;
  border: 3px solid #E5E7EB; border-top-color: #4F46E5;
  border-radius: 50%; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-timer { display: block; font-size: 20px; font-weight: 700; color: #4F46E5; margin-bottom: 8px; }
.loading-tip { display: block; font-size: 14px; color: #6B7280; margin-bottom: 16px; }
.loading-dots { display: flex; justify-content: center; gap: 24px; margin-bottom: 6px; }
.dot { width: 10px; height: 10px; border-radius: 50%; background: #E5E7EB; transition: background 0.3s; }
.dot.active { background: #4F46E5; }
.loading-dot-label { font-size: 11px; color: #D1D5DB; display: block; }
